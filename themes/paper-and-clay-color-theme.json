    "editor.stackFrameHighlightBackground": "#c9883a22",
    "editor.focusedStackFrameHighlightBackground": "#d9775729",

    "extensionButton.prominentBackground": "#d97757",
    "extensionButton.prominentForeground": "#2a1d16",
    "extensionButton.prominentHoverBackground": "#e8916f",
    "extensionBadge.remoteBackground": "#d97757",
    "extensionBadge.remoteForeground": "#2a1d16",

    "textLink.foreground": "#e8916f",
    "textLink.activeForeground": "#d97757",
    "textBlockQuote.background": "#232220",
