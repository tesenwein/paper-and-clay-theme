    "gitDecoration.ignoredResourceForeground": "#5f5c54",
    "gitDecoration.conflictingResourceForeground": "#e8916f",
    "gitDecoration.addedResourceForeground": "#9aa66e",
    "gitDecoration.stageModifiedResourceForeground": "#e0a45a",
