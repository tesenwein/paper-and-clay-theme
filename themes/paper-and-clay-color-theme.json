  "tokenColors": [
    {
      "name": "Comments — recede into the paper",
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#5f5c54", "fontStyle": "italic" }
    },
    {
      "name": "Default text",
      "scope": ["source", "variable", "meta", "punctuation"],
      "settings": { "foreground": "#c4c0b4" }
    },
    {
      "name": "Punctuation, separators — soft",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.section",
        "punctuation.definition.tag",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": { "foreground": "#8b877c" }
    },
    {
      "name": "Keywords — the workshop's heartbeat (coral)",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage.type",
        "storage.modifier",
        "storage",
        "keyword.declaration"
      ],
      "settings": { "foreground": "#d97757" }
    },
    {
      "name": "Operators — neutral so coral keywords stand out",
      "scope": ["keyword.operator", "punctuation.accessor"],
      "settings": { "foreground": "#8b877c" }
    },
    {
      "name": "Strings — sage from the garden",
      "scope": ["string", "string.quoted", "string.template", "meta.string"],
      "settings": { "foreground": "#9aa66e" }
    },
    {
      "name": "String escapes & interpolations",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "punctuation.definition.string",
        "punctuation.section.embedded",
        "meta.embedded"
      ],
      "settings": { "foreground": "#d4b896" }
    },
    {
      "name": "Numbers, booleans, null — warm amber",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.other.color"
      ],
      "settings": { "foreground": "#c9883a" }
    },
    {
      "name": "Constants & enums — amber leaning warm",
      "scope": ["constant", "variable.other.constant", "support.constant"],
      "settings": { "foreground": "#c9883a" }
    },
    {
      "name": "Functions & methods — parchment",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "meta.function entity.name.function",
        "variable.function"
      ],
      "settings": { "foreground": "#d4b896" }
    },
    {
      "name": "Classes, types, interfaces — soft terracotta",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.class",
        "support.type",
        "meta.type"
      ],
      "settings": { "foreground": "#c89478" }
    },
    {
      "name": "Decorators & annotations",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#e8916f", "fontStyle": "italic" }
    },
    {
      "name": "Variables — neutral cream-grey",
      "scope": ["variable.other", "variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#c4c0b4" }
    },
    {
      "name": "Object properties — full cream paper",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name",
        "meta.property.object",
        "variable.other.object.property"
      ],
      "settings": { "foreground": "#f3f0e7" }
    },
    {
      "name": "this / self / super — coral (it's *you*)",
      "scope": ["variable.language.this", "variable.language.self", "variable.language.super"],
      "settings": { "foreground": "#d97757", "fontStyle": "italic" }
    },

    {
      "$comment": "── Markup / Markdown ────────────────────────────────",
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "markup.heading.markdown punctuation.definition.heading"
      ],
      "settings": { "foreground": "#e8916f", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#f3f0e7", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#c4c0b4", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#d4b896" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link", "string.other.link", "constant.other.reference.link"],
      "settings": { "foreground": "#e8916f", "fontStyle": "underline" }
    },
    {
      "name": "Markdown quote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#8b877c", "fontStyle": "italic" }
    },
    {
      "name": "Markdown list bullets",
      "scope": ["markup.list", "punctuation.definition.list.begin"],
      "settings": { "foreground": "#d97757" }
    },

    {
      "$comment": "── HTML / JSX / Vue ─────────────────────────────────",
      "name": "Tags",
      "scope": ["entity.name.tag", "meta.tag.sgml", "punctuation.definition.tag.html"],
      "settings": { "foreground": "#d97757" }
    },
    {
      "name": "Tag attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#d4b896", "fontStyle": "italic" }
    },
    {
      "name": "JSX/TSX components",
      "scope": ["support.class.component", "entity.name.tag.tsx", "entity.name.tag.jsx"],
      "settings": { "foreground": "#c89478" }
    },

    {
      "$comment": "── CSS ──────────────────────────────────────────────",
      "name": "CSS selectors",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#c89478" }
    },
    {
      "name": "CSS property names",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#d4b896" }
    },
    {
      "name": "CSS units",
      "scope": ["keyword.other.unit", "constant.numeric.css"],
      "settings": { "foreground": "#c9883a" }
    },

    {
      "$comment": "── JSON ─────────────────────────────────────────────",
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.json string.quoted.double.json"
      ],
      "settings": { "foreground": "#e8916f" }
    },

    {
      "$comment": "── Diff ─────────────────────────────────────────────",
      "name": "Diff added",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#9aa66e" }
    },
    {
      "name": "Diff removed",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#e05c5c" }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#c9883a" }
    },

    {
      "$comment": "── Invalid / deprecated ─────────────────────────────",
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#e05c5c", "fontStyle": "underline" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#8b877c", "fontStyle": "strikethrough" }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#c4c0b4",
    "class": "#c89478",
